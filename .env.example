# MedBridge AI - environment template
# Copy this file to `.env` and fill in your key(s).

# Option 1: OpenRouter (preferred - one key, many models)
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Option 2: Native Anthropic key (fallback if OpenRouter is not set)
ANTHROPIC_API_KEY=your-anthropic-key-here
